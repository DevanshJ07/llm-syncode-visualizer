# Copy this file to .env and fill in values before running the backend.

APP_NAME="LLM Syncode Visualizer API"
DEBUG=false

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# HuggingFace model
MODEL_NAME=meta-llama/Meta-Llama-3-3B
DEVICE=cuda          # cuda | cpu | mps

MAX_NEW_TOKENS=512
DEFAULT_TOP_K=50

# Where experiments are persisted
EXPERIMENTS_DIR=logs/experiments

# Set to false to run without Syncode (no grammar constraints)
SYNCODE_ENABLED=true
