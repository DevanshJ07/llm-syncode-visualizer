# Copy this file to .env and fill in values before running the backend.

APP_NAME="LLM Syncode Visualizer API"
DEBUG=false

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# Model — TinyLlama is CPU-compatible (~2.2 GB RAM, fp32)
# Switch to meta-llama/Meta-Llama-3-3B once a GPU is available
MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0
DEVICE=cpu          # cpu | cuda | mps

MAX_NEW_TOKENS=64
DEFAULT_TOP_K=10

# Where experiment JSON files are persisted
EXPERIMENTS_DIR=logs/experiments

# Syncode not yet implemented — keep false
SYNCODE_ENABLED=false
