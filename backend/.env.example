# Copy this file to .env and fill in values before running the backend.

APP_NAME="LLM Syncode Visualizer API"
DEBUG=false

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# Model — Qwen2.5-Coder-1.5B-Instruct is CPU-compatible (~3 GB RAM, fp32)
MODEL_NAME=Qwen/Qwen2.5-Coder-1.5B-Instruct
DEVICE=cpu          # cpu | cuda | mps

MAX_NEW_TOKENS=64
DEFAULT_TOP_K=10

# Where experiment JSON files are persisted
EXPERIMENTS_DIR=logs/experiments

# Syncode grammar-constrained decoding.
# Requires: pip install syncode  (syncode>=0.4.0)
# true = load Syncode C-grammar processor on startup (recommended)
# false = skip Syncode; every request uses raw mode regardless of use_syncode
SYNCODE_ENABLED=true
